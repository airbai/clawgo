# Claw Go runtime settings
CLAWGO_API_BASE=https://api.example.com
CLAWGO_API_KEY=replace-with-secret
CLAWGO_DEFAULT_TZ=Asia/Shanghai
CLAWGO_FREE_DAILY_LIMIT=1
CLAWGO_PRO_DAILY_LIMIT=3
CLAWGO_IMAGE_MODE=generate
CLAWGO_IMAGE_API_BASE=https://api.siliconflow.cn/v1/images/generations
CLAWGO_IMAGE_API_KEY=replace-with-image-api-key
CLAWGO_IMAGE_MODEL=Kwai-Kolors/Kolors
CLAWGO_TTS_API_BASE=https://api.siliconflow.cn/v1/audio/speech
CLAWGO_TTS_API_KEY=replace-with-tts-api-key
CLAWGO_TTS_MODEL=fnlp/MOSS-TTSD-v0.5
CLAWGO_TTS_VOICE=fnlp/MOSS-TTSD-v0.5:claire
